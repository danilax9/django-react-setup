#!/bin/bash
set -e

# Проверка запуска от root
if [ "$EUID" -ne 0 ]; then
  echo "Пожалуйста, запускай скрипт с sudo или от root"
  exit 1
fi

echo "Обновляем систему..."
apt update && apt upgrade -y

echo "Устанавливаем nginx, python3, pip, git, nodejs, npm, software-properties-common..."
apt install -y nginx python3 python3-pip git nodejs npm software-properties-common curl

echo "Добавляем репозиторий Yarn и устанавливаем yarn..."
curl -sS https://dl.yarnpkg.com/debian/pubkey.gpg | apt-key add -
echo "deb https://dl.yarnpkg.com/debian/ stable main" > /etc/apt/sources.list.d/yarn.list
apt update
apt install -y yarn

echo "Устанавливаем certbot и плагин для nginx..."
apt install -y certbot python3-certbot-nginx

echo "Базовая настройка сервера завершена."
